# Repo-root environment variables.
#
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Every Python app in this repo (procurement-agent, reviewer-agent,
# mining-agent, procurement-agent/scripts) autoloads this file at startup
# via python-dotenv, regardless of which directory you run them from.
#
# The Next.js UI uses its own .env.local — see procurement-agent/ui/.env.local.example.

# -----------------------------------------------------------------------------
# Required — LLM provider
# -----------------------------------------------------------------------------
# Used by procurement-agent (via LangChain), reviewer-agent (Anthropic SDK
# directly), and mining-agent (Claude Agent SDK).
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Required — Arize AX (tracing + annotations)
# -----------------------------------------------------------------------------
# From https://app.arize.com — settings > API Keys, then copy the Space ID
# from your browser URL (base64 string after /spaces/).
ARIZE_API_KEY=
ARIZE_SPACE_ID=

# -----------------------------------------------------------------------------
# Optional — procurement-agent runtime variant
# -----------------------------------------------------------------------------
# Selects a config bundle from experiments/variants/<id>/. Unset = baseline.
# Flips both the SQLite DB path (data/procurement-<id>.db) and the Arize
# project name (procurement-agent-<id>).
# EXPERIMENT_VARIANT=cycle-1-A

# -----------------------------------------------------------------------------
# Optional — reviewer-agent / scripts / UI -> procurement-agent endpoint
# -----------------------------------------------------------------------------
# Where the reviewer + seed scripts find the running agent. Defaults to
# http://localhost:8000.
# PROCUREMENT_AGENT_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Optional — reviewer-agent institutional-knowledge path
# -----------------------------------------------------------------------------
# Override the path to Vera Fye's institutional-knowledge markdown.
# Defaults to reviewer-agent/institutional-knowledge.md.
# REVIEWER_KNOWLEDGE_PATH=

# -----------------------------------------------------------------------------
# Optional — bulk seed script tuning
# -----------------------------------------------------------------------------
# SEED_PARALLELISM=10
# SEED_TIMEOUT_SECONDS=180
